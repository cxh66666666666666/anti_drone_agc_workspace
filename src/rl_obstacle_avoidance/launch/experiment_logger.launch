<?xml version="1.0"?>
<launch>
    <!-- 实验数据记录节点 — 不改控制链路，仅订阅话题输出 CSV -->
    <arg name="output_dir" default="$(env HOME)/anti_drone_agc_workspace/experiment_data" doc="CSV 输出目录"/>
    <arg name="record_rate" default="10.0" doc="记录频率 (Hz)"/>

    <node pkg="rl_obstacle_avoidance"
          type="experiment_logger_node.py"
          name="experiment_logger_node"
          output="screen">
        <param name="output_dir" value="$(arg output_dir)"/>
        <param name="record_rate" value="$(arg record_rate)"/>
    </node>
</launch>
