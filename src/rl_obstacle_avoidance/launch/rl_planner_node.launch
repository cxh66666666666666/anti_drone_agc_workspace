<launch>
    <!-- RL规划节点参数 -->
    <node pkg="rl_obstacle_avoidance"
          type="rl_planner_node.py"
          name="rl_planner_node"
          output="screen">
        <param name="step_xy" value="1.5" />
        <param name="step_z" value="0.3" />
        <param name="min_height" value="1.0" />
        <param name="safe_distance_norm" value="0.35" />
        <param name="max_offset_xy" value="1.2" />
        <param name="min_offset_xy" value="0.3" />
        <param name="max_offset_z" value="0.3" />
        <param name="emergency_dist_norm" value="0.15" />
        <param name="no_obstacle_threshold" value="0.95" />
        <param name="avoid_hold_time" value="1.5" />
        <param name="side_avoid_gain" value="0.5" />
        <param name="offset_smooth_alpha" value="0.8" />
        <param name="use_yaw_rotation" value="false" />
    </node>
</launch>
