<?xml version="1.0"?>
<launch>
  <!-- LQR轨迹跟踪节点 - 仿真环境专用 -->
  <arg name="mavros_ns" default="/mavros" doc="MAVROS命名空间"/>
  <arg name="rviz" default="true" doc="是否启动RViz"/>
  
  <!-- 启动RViz -->
  <node if="$(arg rviz)" pkg="rviz" type="rviz" name="rviz" args="-d $(find lqr_trajectory_tracker)/rviz/lqr_tracker.rviz"/>
  
  <node pkg="lqr_trajectory_tracker" type="lqr_tracker_node" name="lqr_tracker_node" output="screen">
    <!-- 轨迹类型: linear, circular, helical, random, fixed_horizontal -->
    <param name="trajectory_type" value="fixed_horizontal" />
    
    <!-- 轨迹持续时间 [秒] -->
    <param name="trajectory_duration" value="30.0" />
    
    <!-- 控制频率 [Hz] -->
    <param name="control_rate" value="50.0" />
    
    <!-- LQR权重参数 - 位置误差权重 -->
    <param name="q_pos_xy" value="10.0" />
    <param name="q_pos_z" value="15.0" />
    
    <!-- LQR权重参数 - 速度误差权重 -->
    <param name="q_vel_xy" value="1.0" />
    <param name="q_vel_z" value="2.0" />
    
    <!-- LQR权重参数 - 控制量权重 -->
    <param name="r_accel" value="0.1" />
    
    <!-- 圆形/螺旋轨迹参数 - 适合XTDrone仿真环境 -->
    <param name="center_x" value="0.0" />
    <param name="center_y" value="0.0" />
    <param name="center_z" value="5.0" />
    <param name="radius" value="3.0" />
    <param name="height" value="5.0" />
    <param name="angular_velocity" value="0.3" />
    
    <!-- 直线轨迹参数 -->
    <param name="start_x" value="0.0" />
    <param name="start_y" value="0.0" />
    <param name="start_z" value="2.0" />
    <param name="end_x" value="10.0" />
    <param name="end_y" value="0.0" />
    <param name="end_z" value="5.0" />

    <!-- 随机轨迹参数 - 适配indoor1.world室内环境 -->
    <param name="random_num_waypoints" value="10" />
    <param name="random_space_min_x" value="-10.0" />
    <param name="random_space_max_x" value="10.0" />
    <param name="random_space_min_y" value="-10.0" />
    <param name="random_space_max_y" value="10.0" />
    <param name="random_space_min_z" value="1.5" />
    <param name="random_space_max_z" value="3.0" />
    <param name="random_max_velocity" value="3.0" />
    <param name="random_closed_loop" value="false" />
    <param name="random_seed" value="42" />

    <!-- 固定水平8字形轨迹参数 -->
    <param name="fixed_horizontal_left_x" value="-3.0" />
    <param name="fixed_horizontal_left_y" value="0.0" />
    <param name="fixed_horizontal_right_x" value="3.0" />
    <param name="fixed_horizontal_right_y" value="0.0" />
    <param name="fixed_horizontal_radius" value="3.0" />
    <param name="fixed_horizontal_height" value="2.0" />
    <param name="fixed_horizontal_angular_velocity" value="0.5" />
    <param name="trajectory_duration" value="20.0" />

    <!-- 话题重映射 -->
    <remap from="/mavros/local_position/pose" to="$(arg mavros_ns)/local_position/pose"/>
  </node>
</launch>
